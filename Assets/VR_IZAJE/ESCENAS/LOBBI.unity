  voiceClip: {fileID: 8300000, guid: f69033ed90f16d640b0639acc309e61d, type: 3}
  dialogText: "Ahora veremos los accesorios de izaje. Cada uno tiene un uso espec\xEDfico
    y una capacidad m\xE1xima que no debe superarse, llamada CMU o WLL."
