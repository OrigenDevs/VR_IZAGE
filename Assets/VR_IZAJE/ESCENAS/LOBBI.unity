  voiceClip: {fileID: 8300000, guid: 3ff1e98d41b06e44db31eb20120b5fa9, type: 3}
  dialogText: "El izaje es una maniobra donde se levanta y moviliza una carga con
    una gr\xFAa. Para que sea segura, dos personas clave trabajan juntas: el Rigger
    y el Operador de Gr\xFAa."
  textDelay: 2
  autoAvanzar: 0
