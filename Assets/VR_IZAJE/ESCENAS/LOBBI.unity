  m_Script: {fileID: 11500000, guid: 106ccc569dcce5a49bf52b5a660bbf10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 784d1b4d902926340856e09c6cc64ab8, type: 3}
  dialogText: "Luego est\xE1n los grilletes, que pueden ser rectos o de lira, y se
    usan para conectar las eslingas a la carga. Los ganchos deben tener pestillo
    de seguridad o ser auto-bloqueantes para evitar que la carga se suelte. Las anillas
    maestras sirven para unir varios ramales de eslingas al gancho de la gr\xFAa.
    Y los c\xE1ncamos son puntos de anclaje fijos en la propia carga."
  textDelay: 2
  autoAvanzar: 0
  animationTimeline:
  - normalizedTime: 0
    clip: {fileID: 7400000, guid: d7ef867cd13e2d441a3c61b68beed7f2, type: 2}
  objectsToActivate:
  - {fileID: 1362855667}
  objectsToDeactivate:
  - {fileID: 101518715}
