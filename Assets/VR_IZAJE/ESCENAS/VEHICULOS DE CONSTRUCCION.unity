  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogData
  voiceClip: {fileID: 8300000, guid: 382135ef2e6a047428bb95ac150fe202, type: 3}
  dialogText: "Este es el motor di\xE9sel de seis cilindros en l\xEDnea, el coraz\xF3n
    del cami\xF3n de volteo. Genera m\xE1s de 350 caballos de fuerza y est\xE1 dise\xF1ado
    para soportar jornadas extremas de carga y traslado de material. Su sistema de
    turboalimentaci\xF3n le permite mantener la potencia incluso en condiciones de
    altitud o terrenos irregulares."
  textDelay: 2
  autoAvanzar: 0
  animationTimeline:
